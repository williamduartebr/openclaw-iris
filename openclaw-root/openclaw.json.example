{
  "meta": {
    "lastTouchedVersion": "2026.4.2"
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "nvidia/openai/gpt-oss-120b"
      },
      "models": {
        "nvidia/openai/gpt-oss-120b": {}
      },
      "workspace": "/root/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "subagents": {
        "maxConcurrent": 4
      },
      "sandbox": {
        "workspaceAccess": "rw"
      }
    },
    "list": [
      {
        "id": "main",
        "name": "Iris Prime",
        "identity": {
          "name": "Iris Prime",
          "theme": "AI",
          "emoji": "✨"
        },
        "subagents": {
          "allowAgents": [
            "market-intelligence",
            "seo-strategy",
            "consumer-education",
            "buyer-guidance",
            "dealer-growth",
            "visual-storytelling",
            "quality-desk"
          ]
        }
      },
      {
        "id": "market-intelligence",
        "name": "Radar",
        "workspace": "/root/.openclaw/workspace-market-intelligence",
        "agentDir": "/root/.openclaw/agents/market-intelligence/agent",
        "identity": {
          "name": "Radar",
          "theme": "AI",
          "emoji": "📡"
        }
      },
      {
        "id": "seo-strategy",
        "name": "Vector",
        "workspace": "/root/.openclaw/workspace-seo-strategy",
        "agentDir": "/root/.openclaw/agents/seo-strategy/agent",
        "identity": {
          "name": "Vector",
          "theme": "AI",
          "emoji": "🎯"
        }
      },
      {
        "id": "consumer-education",
        "name": "Atlas",
        "workspace": "/root/.openclaw/workspace-consumer-education",
        "agentDir": "/root/.openclaw/agents/consumer-education/agent",
        "identity": {
          "name": "Atlas",
          "theme": "AI",
          "emoji": "📘"
        }
      },
      {
        "id": "buyer-guidance",
        "name": "Navigator",
        "workspace": "/root/.openclaw/workspace-buyer-guidance",
        "agentDir": "/root/.openclaw/agents/buyer-guidance/agent",
        "identity": {
          "name": "Navigator",
          "theme": "AI",
          "emoji": "🧭"
        }
      },
      {
        "id": "dealer-growth",
        "name": "Torque",
        "workspace": "/root/.openclaw/workspace-dealer-growth",
        "agentDir": "/root/.openclaw/agents/dealer-growth/agent",
        "identity": {
          "name": "Torque",
          "theme": "AI",
          "emoji": "📈"
        }
      },
      {
        "id": "visual-storytelling",
        "name": "Frame",
        "workspace": "/root/.openclaw/workspace-visual-storytelling",
        "agentDir": "/root/.openclaw/agents/visual-storytelling/agent",
        "identity": {
          "name": "Frame",
          "theme": "AI",
          "emoji": "🎬"
        }
      },
      {
        "id": "quality-desk",
        "name": "Sentinel",
        "workspace": "/root/.openclaw/workspace-quality-desk",
        "agentDir": "/root/.openclaw/agents/quality-desk/agent",
        "identity": {
          "name": "Sentinel",
          "theme": "AI",
          "emoji": "🛡️"
        }
      }
    ]
  },
  "models": {
    "mode": "merge",
    "providers": {
      "nvidia": {
        "baseUrl": "https://integrate.api.nvidia.com/v1",
        "apiKey": {
          "source": "env",
          "provider": "default",
          "id": "NVIDIA_API_KEY"
        },
        "auth": "token",
        "api": "openai-completions",
        "models": [
          {
            "id": "openai/gpt-oss-120b",
            "name": "NVIDIA GPT OSS 120B",
            "api": "openai-completions",
            "reasoning": false,
            "input": [
              "text"
            ],
            "maxTokens": 4096,
            "compat": {
              "supportsDeveloperRole": true,
              "supportsTools": true,
              "supportsReasoningEffort": false,
              "supportsUsageInStreaming": true,
              "supportsStrictMode": false,
              "maxTokensField": "max_tokens"
            }
          }
        ]
      }
    }
  },
  "tools": {
    "profile": "coding",
    "web": {
      "search": {
        "enabled": true,
        "provider": "gemini",
        "maxResults": 5,
        "timeoutSeconds": 45,
        "cacheTtlMinutes": 0,
        "gemini": {
          "apiKey": "__SET_GEMINI_API_KEY__",
          "model": "gemini-2.5-flash"
        }
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "boot-md": {
          "enabled": true
        },
        "bootstrap-extra-files": {
          "enabled": true
        },
        "command-logger": {
          "enabled": true
        },
        "session-memory": {
          "enabled": true
        }
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "dmPolicy": "pairing",
      "botToken": "__SET_TELEGRAM_BOT_TOKEN__",
      "groupPolicy": "open",
      "streaming": "partial"
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789"
      ]
    },
    "auth": {
      "mode": "token",
      "token": "__SET_GATEWAY_TOKEN__"
    },
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send"
      ]
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true
      }
    }
  }
}
